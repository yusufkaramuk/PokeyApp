<Window x:Class="PokeyApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PokeyApp — Ayarlar"
        Width="360" Height="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAABB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="#1E1E2E"
            BorderBrush="#2D2D44"
            BorderThickness="1"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Başlık -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <Grid Margin="16,12,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚙ Ayarlar"
                               Foreground="White" FontSize="14"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="✕"
                            Foreground="#888899" Background="Transparent"
                            BorderBrush="Transparent" FontSize="13"
                            Cursor="Hand" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="16,4,16,8">

                <TextBlock Text="Kullanıcı adın" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding LocalUsername, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Peer (karşı bilgisayar) — Keşfedilen cihazlar" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding DiscoveredPeers}"
                          SelectedItem="{Binding SelectedDiscoveredPeer}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,8">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#2A2A3E"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <TextBlock Text="Manuel IP adresi" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding PeerIpAddress, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Örn: 192.168.1.42" Foreground="#555566"
                                                               FontFamily="Segoe UI" FontSize="13" Margin="8,6"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Text="TCP Port" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <CheckBox Content="Bildirim sesi"
                          IsChecked="{Binding SoundEnabled}"
                          Foreground="#AAAABB"
                          FontFamily="Segoe UI"
                          FontSize="13"/>
            </StackPanel>

            <!-- Butonlar -->
            <Grid Grid.Row="2" Margin="16,0,16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="İptal"
                        Background="#33334A"
                        Foreground="#AAAABB"
                        Style="{StaticResource ActionButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Click="Cancel_Click"/>

                <Button Grid.Column="2"
                        Content="Kaydet"
                        Background="#6C63FF"
                        Foreground="White"
                        Style="{StaticResource ActionButtonStyle}"
                        Command="{Binding SaveCommand}"
                        Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
