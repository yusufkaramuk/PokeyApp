<Window x:Class="PokeyApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:transport="clr-namespace:PokeyApp.Transport"
        Title="PokeyApp"
        Width="260" Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        Topmost="False">

    <Window.Resources>
        <!-- Bağlantı durumuna göre renk dönüşümü -->
        <Style x:Key="PokeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7B73FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5B54E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#444455"/>
                                <Setter Property="Foreground" Value="#777788"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="#1E1E2E"
            BorderBrush="#2D2D44"
            BorderThickness="1"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Başlık çubuğu (sürüklenebilir) -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Grid Margin="12,8,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="PokeyApp"
                               Foreground="#CCCCDD"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>

                    <!-- Ayarlar -->
                    <Button Grid.Column="1"
                            Content="⚙"
                            Style="{StaticResource IconButtonStyle}"
                            Click="Settings_Click"
                            ToolTip="Ayarlar"/>

                    <!-- Minimize to tray -->
                    <Button Grid.Column="2"
                            Content="—"
                            Style="{StaticResource IconButtonStyle}"
                            Click="MinimizeToTray_Click"
                            ToolTip="Sistem tepsisine küçült"/>

                    <!-- Kapat -->
                    <Button Grid.Column="3"
                            Content="✕"
                            Style="{StaticResource IconButtonStyle}"
                            Click="Close_Click"
                            ToolTip="Kapat"/>
                </Grid>
            </Border>

            <!-- Ana içerik -->
            <StackPanel Grid.Row="1" Margin="12,4,12,8">

                <!-- Bağlantı durumu -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Durum ışığı -->
                    <Ellipse Grid.Column="0"
                             Width="8" Height="8"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionState}"
                                                 Value="{x:Static transport:TransportState.Connected}">
                                        <Setter Property="Fill" Value="#44FF88"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}"
                                                 Value="{x:Static transport:TransportState.Connecting}">
                                        <Setter Property="Fill" Value="#FFAA44"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}"
                                                 Value="{x:Static transport:TransportState.Reconnecting}">
                                        <Setter Property="Fill" Value="#FFAA44"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ConnectionStatusText}"
                               Foreground="#AAAABB"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Dürt butonu -->
                <Button Content="👉  Dürt!"
                        Style="{StaticResource PokeButtonStyle}"
                        Command="{Binding PokeCommand}"
                        Height="38"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
