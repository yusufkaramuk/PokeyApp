<Window x:Class="PokeyApp.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PokeyApp Notification"
        Width="300" Height="70"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height">

    <Window.Resources>
        <Style x:Key="DismissButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="#1E1E2E"
            BorderBrush="#6C63FF"
            BorderThickness="1.5"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="14,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Bell icon -->
            <TextBlock Grid.Column="0"
                       Text="🔔"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <!-- Message -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Message}"
                       Foreground="White"
                       FontSize="13"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <!-- Dismiss button -->
            <Button Grid.Column="2"
                    Content="✕"
                    Style="{StaticResource DismissButtonStyle}"
                    Command="{Binding DismissCommand}"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"/>
        </Grid>
    </Border>
</Window>
